@{
    Layout = "_Layout";
}



@section Scripts {
    <script>
        function atualizarHorarios(data) {
            
            console.log("Função disparada para a data:", data);
            
            if (!data) return;

           
            fetch('/Home/BuscarHorarios?DataSelecionada=' + data)
                .then(response => {
                    if (!response.ok) throw new Error('Erro na resposta do servidor');
                    return response.json();
                })
                .then(horarios => {
                    console.log("Horários recebidos:", horarios);
                    const selectHora = document.getElementById('hora');
                    
                    if (selectHora) {
                        selectHora.innerHTML = '<option value="">Selecione um horário</option>';
                        horarios.forEach(horario => {
                            const option = document.createElement('option');
                            option.value = horario;
                            option.textContent = horario;
                            selectHora.appendChild(option);
                        });
                    }
                })
                .catch(error => console.error('Erro no Fetch:', error));
        }
    </script>
}

    <form method="post" action="/Home/ConfirmarAgendamento">
        <h3>Agendar Corte</h3>

        <label for="nome">Nome:</label>
        <input type="text" id="nome" name="nome" placeholder="Digite Seu nome">
        <br><br>
        <label for="data">data:</label>
        <input type="date" id="data" name="data" required value="@ViewBag.DataSelecionada" onchange="atualizarHorarios(this.value)">
        <br><br>
        <label for="hora">Hora:</label>
        <select type="time" id="hora" name="hora" required>
          <option value="">Selecione um horário</option>
          @if (ViewBag.HorariosDisponiveis != null)
         {
            foreach (var horario in (List<string>)ViewBag.HorariosDisponiveis)
            {
                <option value="@horario">@horario</option>
            }
          }
        </select>
    
        
       <form method="post" action="Home/ConfirmarAgendamento">
        <p>Escolha um serviço</p>
       <label>
        <input type="radio" name="Corte" value="Degrade" required> Degrade - R$ 30,00
    </label><br>
    <label>
        <input type="radio" name="Corte" value="Social" required> Social - R$ 25,00
    </label><br>
    <label>
        <input type="radio" name="Corte" value="Corte e Barba" required> Corte e Barba - R$ 35,00
    </label><br>

    <input type="hidden" name="Valor" value="30.00" /> 

    <button type="submit" class="btn btn-primary">Confirmar Agendamento</button>
    @Html.AntiForgeryToken()
    </form>
    
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
